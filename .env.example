# ════════════════════════════════════════════════════════════════════
#  Obsidian MCP — environment file
#  Copy this to .env and fill in your values.
#  All keys use the prefix  OBSIDIAN_MCP_
# ════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────
OBSIDIAN_MCP_VAULT_PATH=/absolute/path/to/your/ObsidianVault

# ── Server ───────────────────────────────────────────────────────────
OBSIDIAN_MCP_SERVER_NAME=obsidian-mcp
OBSIDIAN_MCP_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ── Permissions ──────────────────────────────────────────────────────
# read_only  — no writes (safe for experimentation)
# safe_write — create/update/append + all plugin writes (recommended)
# admin      — includes delete, move, rename
OBSIDIAN_MCP_PERMISSION_PROFILE=safe_write

# ── Vault adapter ────────────────────────────────────────────────────
# auto       — probe REST API at startup, fall back to filesystem
# rest       — REST API only (Obsidian must be running)
# filesystem — direct .md file access, no Obsidian required
OBSIDIAN_MCP_ADAPTER_MODE=auto

# Leave blank to skip REST probe (pure filesystem mode)
OBSIDIAN_MCP_ADAPTER_API_KEY=
OBSIDIAN_MCP_ADAPTER_HOST=127.0.0.1
OBSIDIAN_MCP_ADAPTER_PORT=27123

# ── Web UI ───────────────────────────────────────────────────────────
OBSIDIAN_MCP_WEB_HOST=127.0.0.1
OBSIDIAN_MCP_WEB_PORT=8765

# ── Templater ────────────────────────────────────────────────────────
# Folder inside the vault where template notes live
OBSIDIAN_MCP_TEMPLATES_FOLDER=Templates
